model absensi_ekstrakurikuler {
  id                              Int                          @id @default(autoincrement())
  sesi_absensi_ekstrakurikuler_id Int
  siswa_id                        Int
  status                          status_absensi
  keterangan                      String?
  dicatat_oleh                    Int?
  dicatat_pada                    DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime                     @default(now()) @db.Timestamptz(6)
  users                           users?                       @relation(fields: [dicatat_oleh], references: [id], onUpdate: NoAction, map: "fk_absensi_ekskul_dicatat_oleh")
  sesi_absensi_ekstrakurikuler    sesi_absensi_ekstrakurikuler @relation(fields: [sesi_absensi_ekstrakurikuler_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_absensi_ekskul_sesi")
  siswa                           siswa                        @relation(fields: [siswa_id], references: [id], onUpdate: NoAction, map: "fk_absensi_ekskul_siswa")

  @@unique([sesi_absensi_ekstrakurikuler_id, siswa_id], map: "uq_absensi_ekskul_siswa_sesi")
  @@index([siswa_id], map: "idx_absensi_ekskul_siswa")
  @@index([status], map: "idx_absensi_ekskul_status")
}

